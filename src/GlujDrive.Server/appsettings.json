{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "CatalogPath": "data/catalog",
    "DefaultFolderPath": "data/photos",
    "MaxUploadBytes": 104857600,
    "MaxBatchUploadBytes": 524288000
  },
  "SemanticSearch": {
    "Enabled": true,
    "DataPath": "data/catalog/semantic",
    "RuntimeLibraryPath": "runtime/win-x64/GlujDrive.Inference.Native.dll",
    "BundledPackagePath": "ai/TinyCLIP-ncnn-win-x64.zip",
    "BundledPackageSha256Path": "ai/TinyCLIP-ncnn-win-x64.zip.sha256",
    "ModelPackageUrl": null,
    "ModelPackageSha256": null,
    "IdleUnloadMinutes": 5
  },
  "AllowedHosts": "*"
}
