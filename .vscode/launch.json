{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Gluj Drive: Server",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "backend: build",
      "program": "${workspaceFolder}/src/GlujDrive.Server/bin/Debug/net10.0-windows/GlujDrive.Server.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/GlujDrive.Server",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5199"
      }
    },
    {
      "name": "Gluj Drive: Web (Edge)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm.cmd run dev",
      "cwd": "${workspaceFolder}/src/GlujDrive.Web",
      "serverReadyAction": {
        "action": "debugWithEdge",
        "pattern": "Local:.*(http://localhost:5173/)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/src/GlujDrive.Web"
      }
    }
  ],
  "compounds": [
    {
      "name": "Gluj Drive: Full stack",
      "configurations": [
        "Gluj Drive: Server",
        "Gluj Drive: Web (Edge)"
      ],
      "stopAll": true
    }
  ]
}
