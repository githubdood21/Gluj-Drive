{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/GlujDrive.slnx"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "frontend: install",
      "type": "process",
      "command": "npm.cmd",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/GlujDrive.Web"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: build",
      "type": "process",
      "command": "npm.cmd",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/GlujDrive.Web"
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "frontend: lint",
      "type": "process",
      "command": "npm.cmd",
      "args": [
        "run",
        "lint"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/GlujDrive.Web"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: dev",
      "type": "process",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/GlujDrive.Web"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "build: all",
      "dependsOn": [
        "backend: build",
        "frontend: build"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "publish: windows",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/src/GlujDrive.Server/GlujDrive.Server.csproj",
        "--configuration",
        "Release"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
